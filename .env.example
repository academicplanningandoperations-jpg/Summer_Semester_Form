# ─── SMTP (email for OTP delivery) ──────────────────────────────────────────
# For Microsoft 365 / Outlook (common at UPES)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=apo@ddn.upes.ac.in
SMTP_PASS=Hop83939
SMTP_FROM="Summer Semester Form <noreply@ddn.upes.ac.in>"

# If SMTP_USER is not set, the server runs in DEV MODE:
# OTPs are printed to the console instead of emailed — useful for testing.

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Admin panel password
ADMIN_PASSWORD=admin@321

# ─── App settings ────────────────────────────────────────────────────────────
PORT=3000
MAX_COURSES=5
